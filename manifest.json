{
  "manifest_version": 3,
  "name": "DocSense Companion",
  "description": "AI-Powered Knowledge Capture Extension for DocSense AI. Capture knowledge from anywhere, save it forever.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "DocSense Companion"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "activeTab",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "save-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current page to DocSense"
    }
  }
}
